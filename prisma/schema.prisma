generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  COMPANY
}

enum Modality {
  REMOTE
  ONSITE
  HYBRID
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum PipelineStatus {
  PENDING
  REVIEWING
  INTERVIEW
  REJECTED
}

enum ModuleType {
  SKILLS
  EXPERIENCE
  EDUCATION
  LANGUAGES
  PORTFOLIO
  CUSTOM
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MessageType {
  TEXT
  INTERVIEW
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  APPLICATION_REVIEWED
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  lastName     String?
  rut          String?  @unique
  phone        String?
  role         Role
  image        String?
  provider     String?
  providerId   String?
  passwordHash  String?
  resetToken    String?   @unique
  resetTokenExp DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  studentProfile StudentProfile?
  companyProfile CompanyProfile?
  applications   Application[]

  companyConversations Conversation[] @relation("CompanyConversations")
  studentConversations Conversation[] @relation("StudentConversations")
  sentMessages         Message[]
  companyInterviews    Interview[]    @relation("CompanyInterviews")
  studentInterviews    Interview[]    @relation("StudentInterviews")
  notifications        Notification[]

  @@map("users")
}

model StudentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  university String?
  career    String?
  semester  Int?
  skills    String[]
  bio       String?
  cvUrl     String?
  cvText    String?
  cvParsed  Json?
  embedding Float[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("student_profiles")
}

model CompanyProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  empresaRut    String?
  companyStatus CompanyStatus @default(PENDING)
  industry      String?
  website       String?
  logo          String?
  description   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  internships Internship[]

  @@map("company_profiles")
}

model Internship {
  id           String    @id @default(cuid())
  companyId    String
  company      CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title        String
  description  String
  area         String
  location     String
  modality     Modality
  duration     String
  requirements String[]
  skills       String[]
  embedding    Float[]
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  applications Application[]
  atsConfig    ATSConfig?
  interviews   Interview[]

  @@map("internships")
}

model Application {
  id           String            @id @default(cuid())
  studentId    String
  student      User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internshipId String
  internship   Internship        @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  status         ApplicationStatus @default(PENDING)
  matchScore     Float?
  coverLetter    String?
  atsScore       Float?
  moduleScores   Json?
  passedFilters  Boolean        @default(true)
  filterReason   String?
  pipelineStatus PipelineStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  conversation Conversation?
  interview    Interview?

  @@unique([studentId, internshipId])
  @@map("applications")
}

model ATSConfig {
  id           String      @id @default(cuid())
  internshipId String      @unique
  internship   Internship  @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  isActive     Boolean     @default(true)
  modules      ATSModule[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("ats_configs")
}

model ATSModule {
  id          String     @id @default(cuid())
  atsConfigId String
  atsConfig   ATSConfig  @relation(fields: [atsConfigId], references: [id], onDelete: Cascade)
  type        ModuleType
  label       String
  isActive    Boolean    @default(true)
  weight      Int
  order       Int
  params      Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("ats_modules")
}

model Conversation {
  id             String       @id @default(cuid())
  companyId      String
  studentId      String
  applicationId  String       @unique
  company        User         @relation("CompanyConversations", fields: [companyId], references: [id])
  student        User         @relation("StudentConversations", fields: [studentId], references: [id])
  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  messages       Message[]
  interviews     Interview[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([companyId])
  @@index([studentId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])
  content        String       @db.Text
  type           MessageType  @default(TEXT)
  metadata       Json?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

model Interview {
  id             String          @id @default(cuid())
  companyId      String
  studentId      String
  internshipId   String
  applicationId  String          @unique
  conversationId String
  company        User            @relation("CompanyInterviews", fields: [companyId], references: [id])
  student        User            @relation("StudentInterviews", fields: [studentId], references: [id])
  internship     Internship      @relation(fields: [internshipId], references: [id])
  application    Application     @relation(fields: [applicationId], references: [id])
  conversation   Conversation    @relation(fields: [conversationId], references: [id])
  title          String
  scheduledAt    DateTime
  durationMins   Int             @default(60)
  meetingLink    String?
  notes          String?         @db.Text
  sentToChat     Boolean         @default(false)
  sentToChatAt   DateTime?
  status         InterviewStatus @default(SCHEDULED)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId])
  @@index([scheduledAt])
  @@map("interviews")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  entityId  String?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@map("notifications")
}
